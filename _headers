# ── Service worker ──────────────────────────────────────────────────────────
# Must always be revalidated so browsers pick up new precache lists the
# moment sw.js's CACHE version is bumped -- this is the file that has
# caused every "stale page" bug this project has hit, so it stays on the
# strictest policy on purpose.
/sw.js
  Cache-Control: no-cache, must-revalidate

# ── Fonts / icons / manifest ────────────────────────────────────────────────
# These almost never change, so a long TTL is safe.
/favicon.ico
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/icon-192.png
  Cache-Control: public, max-age=2592000
/icon-512.png
  Cache-Control: public, max-age=2592000
/icon-192-maskable.png
  Cache-Control: public, max-age=2592000
/icon-512-maskable.png
  Cache-Control: public, max-age=2592000
/og-image.png
  Cache-Control: public, max-age=2592000
/hero.png
  Cache-Control: public, max-age=604800
/manifest.json
  Cache-Control: public, max-age=3600

# ── CSS / JS ─────────────────────────────────────────────────────────────────
# NOT filename-versioned in this codebase (no content hash in the path), so
# a full "immutable, 1 year" policy is unsafe here -- it would leave every
# visitor's browser on stale app code for weeks after a deploy with no way
# to bust it short of renaming the file. A shorter TTL still eliminates most
# repeat-visit origin requests while keeping same-day deploys effective.
# Revisit this once/if these assets get build-time content hashing.
/css/*
  Cache-Control: public, max-age=86400, must-revalidate
/js/*
  Cache-Control: public, max-age=86400, must-revalidate

# ── Images ───────────────────────────────────────────────────────────────────
# Every current image file already has an explicit rule above (see
# "Fonts / icons / manifest"). Deliberately NOT adding a generic /*.png-style
# catch-all here: Cloudflare Pages merges every matching _headers rule
# instead of letting a more specific path win, so a wildcard image rule
# stacks a second, duplicate Cache-Control value onto any file that also has
# an explicit rule (confirmed live -- produced a malformed header on
# icon-192.png/og-image.png/hero.png before this was removed). Add a new
# explicit entry above when a new image file is added instead.

# ── Marketing / public content pages ────────────────────────────────────────
# Safe to cache briefly at the edge (s-maxage) -- content doesn't change
# minute to minute -- while keeping the browser copy (max-age) short so a
# fresh deploy is visible on next navigation, not just next hard refresh.
