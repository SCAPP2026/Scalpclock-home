# ── Live/real-time product pages ────────────────────────────────────────────
# Publicly reachable (no login redirect), but explicitly listed as
# "do not cache" -- these render live chart/signal data client-side and
# correctness there matters more than the caching win.
/scalpchart
  Cache-Control: no-store
/exitassistant
  Cache-Control: no-store
/signals
  Cache-Control: no-store

# ── Account / dashboard / session pages ─────────────────────────────────────
# Cloudflare Pages doesn't edge-cache HTML by default today, so this is a
# safety net against that default ever changing (via a future Cache Rule,
# a platform update, etc.), not a fix for an active bug.
/dashboard
  Cache-Control: no-store
/login
  Cache-Control: no-store
/settings
  Cache-Control: no-store
/journal
  Cache-Control: no-store
/news
  Cache-Control: no-store
/referrals
  Cache-Control: no-store
/admin-referrals
